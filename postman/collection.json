{
  "info": {
    "name": "Fitness Challenge Tracker API",
    "_postman_id": "0f9f52fb-27ff-4a48-9b69-cd6a5e4c2e11",
    "description": "Postman collection for testing the Fitness Challenge Tracker API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Root (Health Check)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        }
        ,
        {
          "name": "API Health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/health"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Rahul\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          },
          "response": []
          ,
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201 or 400 (already exists)', function () {",
                  "  pm.expect([201, 400]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 201) {",
                  "  const jsonData = pm.response.json();",
                  "  if (jsonData && jsonData.token) pm.environment.set('token', jsonData.token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "  pm.environment.set('token', jsonData.token);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Challenges",
      "item": [
        {
          "name": "Create Challenge",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"10k Steps Daily\",\n  \"description\": \"Walk 10,000 steps everyday\",\n  \"startDate\": \"2026-05-03\",\n  \"endDate\": \"2026-05-31\",\n  \"target\": 10000,\n  \"progress\": 0,\n  \"status\": \"active\"\n}"
            },
            "url": "{{baseUrl}}/api/challenges"
          },
          "response": []
          ,
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const jsonData = pm.response.json();",
                  "const id = jsonData && jsonData.challenge && (jsonData.challenge._id || jsonData.challenge.id);",
                  "if (id) pm.environment.set('challengeId', id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get All Challenges",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/challenges"
          },
          "response": []
        },
        {
          "name": "Get Active Challenges",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/challenges/active"
          },
          "response": []
        },
        {
          "name": "Get Completed Challenges",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/challenges/completed"
          },
          "response": []
        },
        {
          "name": "Get Challenge By ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/challenges/{{challengeId}}"
          },
          "response": []
        },
        {
          "name": "Update Challenge (PUT)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"10k Steps Daily (Updated)\",\n  \"target\": 12000\n}"
            },
            "url": "{{baseUrl}}/api/challenges/{{challengeId}}"
          },
          "response": []
        },
        {
          "name": "Update Progress",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"progress\": 5000\n}"
            },
            "url": "{{baseUrl}}/api/challenges/{{challengeId}}/progress"
          },
          "response": []
        },
        {
          "name": "Delete Challenge",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/challenges/{{challengeId}}"
          },
          "response": []
        }
      ]
    }
  ]
}
